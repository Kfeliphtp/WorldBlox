local function tornarMovel(frame)
	local dragging
	local dragInput
	local dragStart
	local startPos
	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)
	frame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

local function criarBotoesJanela(panel, mainPanel, newPanel)
	local minimizado = false
	local tamanhoNormal = panel.Size
	local homeBtn = Instance.new("TextButton")
	homeBtn.Parent = panel
	homeBtn.Size = UDim2.new(0,80,0,30)
	homeBtn.Position = UDim2.new(0,500,0,10)
	homeBtn.BackgroundTransparency = 1
	homeBtn.Text = "Home"
	homeBtn.TextSize = 14
	homeBtn.TextScaled = false
	local corTextoNormal = Color3.fromRGB(9, 18, 202)
	local corTextoHover = Color3.fromRGB(109, 5, 213)
	homeBtn.TextColor3 = corTextoNormal
	-- HOVER TEXTO
	homeBtn.MouseEnter:Connect(function()
		homeBtn.TextColor3 = corTextoHover
	end)
	homeBtn.MouseLeave:Connect(function()
		homeBtn.TextColor3 = corTextoNormal
	end)
	homeBtn.MouseButton1Click:Connect(function()
		mainPanel.Visible = true

		if panel ~= mainPanel then
			panel.Visible = false
		end
	end)
	-- BOTÃO MINIMIZAR
	local minBtn = Instance.new("TextButton")
	minBtn.Parent = panel
	minBtn.Size = UDim2.new(0,25,0,25)
	minBtn.Position = UDim2.new(1,-60,0,0)
	minBtn.BackgroundTransparency = 1
	minBtn.Text = "–"
	minBtn.TextScaled = true
	minBtn.TextColor3 = Color3.new(1,1,1)
	-- BOTÃO FECHAR
	local closeBtn = Instance.new("TextButton")
	closeBtn.Parent = panel
	closeBtn.Size = UDim2.new(0,25,0,25)
	closeBtn.Position = UDim2.new(1,-35,0,0)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Text = "x"
	closeBtn.TextScaled = true
	closeBtn.TextColor3 = Color3.new(1,1,1)
	-- MINIMIZAR
	minBtn.MouseButton1Click:Connect(function()
		minimizado = not minimizado

		if minimizado then
			panel.Size = UDim2.new(
				tamanhoNormal.X.Scale,
				tamanhoNormal.X.Offset,
				0,
				30
			)
			panel.ImageTransparency = 1
			panel.BackgroundColor3 = Color3.fromRGB(0,0,0)
			panel.BackgroundTransparency = 0
		else
			panel.Size = tamanhoNormal
			panel.ImageTransparency = 0
		end
		for _,obj in pairs(panel:GetChildren()) do
			if obj ~= minBtn and obj ~= closeBtn then
				obj.Visible = not minimizado
			end
		end
	end)
	-- FECHAR
	closeBtn.MouseButton1Click:Connect(function()
		panel.Visible = false
	end)
end





