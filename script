-------------------------------------------------
-- COOLDOWN
-------------------------------------------------

local cooldown = {}

-------------------------------------------------
-- AUTO BUY
-------------------------------------------------

local function autoBuyFunc()

	for _,v in pairs(workspace:GetDescendants()) do

		if v:IsA("ProximityPrompt") then

			for raridade,ativo in pairs(autoBuy) do

				if ativo and lists[raridade][v.ObjectText] then

					if not cooldown[v] then
						cooldown[v] = true

						fireproximityprompt(v, 1)

						task.delay(2,function()
							cooldown[v] = nil
						end)
					end

				end

			end

		end

	end

end

-------------------------------------------------
-- LOOP
-------------------------------------------------

task.spawn(function()
	while true do
		task.wait(0.2)
		pcall(autoBuyFunc)
	end
end)


