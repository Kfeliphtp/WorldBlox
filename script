local ativo4 = false
local player = game.Players.LocalPlayer

botao4.MouseButton1Click:Connect(function()

	ativo4 = not ativo4

	if ativo4 then
		check4.Text = "▣"
	else
		check4.Text = "☐"
	end

end)

task.spawn(function()

	while task.wait(2) do

		if ativo4 then

			local char = player.Character
			if not char then continue end

			local hrp = char:FindFirstChild("HumanoidRootPart")
			if not hrp then continue end

			local rebirthUI = player.PlayerGui:FindFirstChild("Rebirth")
			if not rebirthUI then continue end

			local brainrots = rebirthUI:FindFirstChild("Brainrots")
			if not brainrots then continue end

			-- pegar brainrot necessário
			for _,ui in pairs(brainrots:GetDescendants()) do

				if ui:IsA("TextLabel") and ui.Text ~= "" then

					local needed = ui.Text

					for _,model in pairs(workspace:GetDescendants()) do

						if model:IsA("Model") then

							local objText = model:FindFirstChild("ObjectText",true)

							if objText and objText:IsA("TextLabel") then

								if string.find(objText.Text,needed) then

									hrp.CFrame = model:GetPivot() + Vector3.new(0,3,0)
									task.wait(1)

								end

							end

						end

					end

				end

			end

			-- tentar rebirth
			pcall(function()

				for _,v in pairs(game:GetDescendants()) do
					if v:IsA("RemoteEvent") and string.find(v.Name:lower(),"rebirth") then
						v:FireServer()
					end
				end

			end)

		end

	end

end)

