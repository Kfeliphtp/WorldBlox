local function abrirFrame(frame)
	if frame.Visible then
		frame.Visible = false
	else
		FrameFarm.Visible = false
		FramePlayers.Visible = false
		FrameEsp.Visible = false

		frame.Visible = true
	end
end

local function abrirPanel(panel)
	-- fecha todos
	HomePanel.Visible = false
	ConfigPanel.Visible = false
	CreditsPanel.Visible = false

	-- abre o que você quer
	panel.Visible = true
end

local function criarBotoesJanela(panel)

	local minimizado = false
	local tamanhoNormal = panel.Size
	

	local Home = Instance.new("TextButton")
	Home.Parent = panel
	Home.BackgroundTransparency = 1
	Home.Position = UDim2.new(0.689830482, 0, 0.0589812323, 0)
	Home.Size = UDim2.new(0, 58, 0, 18)
	Home.Font = Enum.Font.DenkOne
	Home.Text = "Home"
	Home.TextSize = 18
	Home.TextScaled = false
	local corTextoNormal = Color3.fromRGB(120, 115, 255)
	local corTextoHover = Color3.fromRGB(91, 87, 194)

	Home.TextColor3 = corTextoNormal

	Home.MouseEnter:Connect(function()
		Home.TextColor3 = corTextoHover
	end)

	Home.MouseLeave:Connect(function()
		Home.TextColor3 = corTextoNormal
	end)

	Home.MouseButton1Click:Connect(function()
		abrirPanel(HomePanel)
	end)
	
	-------------------------
	-- BOTÃO MINIMIZAR
	-------------------------
	local minimize = Instance.new("TextButton")
	minimize.Parent = panel
	minimize.BackgroundTransparency = 1
	minimize.Position = UDim2.new(0.91, 0, 0, 0)
	minimize.Size = UDim2.new(0, 23, 0, 22)
	minimize.Text = "–"
	minimize.TextColor3 = Color3.fromRGB(255,255,255)
	minimize.TextSize = 20

	-------------------------
	-- BOTÃO FECHAR
	-------------------------
	local close = Instance.new("TextButton")
	close.Parent = panel
	close.BackgroundTransparency = 1
	close.Position = UDim2.new(0.96, 0, 0, 0)
	close.Size = UDim2.new(0, 23, 0, 22)
	close.Text = "x"
	close.TextColor3 = Color3.fromRGB(255,255,255)
	close.TextSize = 20

	-------------------------
	-- MINIMIZAR
	-------------------------
	minimize.MouseButton1Click:Connect(function()

		minimizado = not minimizado

		if minimizado then
			panel.Size = UDim2.new(panel.Size.X.Scale, panel.Size.X.Offset, 0, 30)
			panel.BackgroundColor3 = Color3.fromRGB(0,0,0)
			panel.ImageTransparency = 1
			panel.BackgroundTransparency = 0
		else
			panel.Size = tamanhoNormal
			panel.ImageTransparency = 0
			panel.BackgroundTransparency = 1
		end

		for _,obj in pairs(panel:GetChildren()) do
			if obj ~= minimize and obj ~= close then
				obj.Visible = not minimizado
			end
		end

	end)

	-------------------------
	-- FECHAR
	-------------------------
	close.MouseButton1Click:Connect(function()
		panel.Visible = false
	end)

end

