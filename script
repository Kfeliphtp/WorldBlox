function ESPBrainrot()

	while selecionados["Brainrot"] do

		for _,v in pairs(workspace:GetDescendants()) do

			if string.find(string.lower(v.Name), "brainrot") then

				local part

				if v:IsA("Model") then
					part = v:FindFirstChild("HumanoidRootPart") 
						or v.PrimaryPart 
						or v:FindFirstChildWhichIsA("BasePart")
				elseif v:IsA("BasePart") then
					part = v
				end

				if part and not part:FindFirstChild("ESPLabel") then

					criarESP(
						part,
						v.Name,
						Color3.fromRGB(255,0,255)
					)

				end

			end

		end

		task.wait(2)

	end

end

