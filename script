local function coletar()

	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("BasePart") and v.Name == "Collect" then
			firetouchinterest(hrp, v, 0)
			firetouchinterest(hrp, v, 1)
		end
	end
end

task.spawn(function()
	while task.wait(0.5) do
		if ativo1 then
			pcall(function()
				coletar()
			end)
		end
	end
end)

