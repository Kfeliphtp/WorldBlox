	"Mythic",
	"Secret",
	"Stellar"
}

for i,v in ipairs(options) do

	local option = Instance.new("TextButton")
	option.Parent = dropdownMenu
	option.Size = UDim2.new(1,0,0,30)
	option.Position = UDim2.new(0,5,0,(i-1)*30)
	option.BackgroundTransparency = 1
	
	option.Text = "   "..v.."  ☐"
	option.TextColor3 = Color3.new(1,1,1)
	option.TextSize = 12
	option.TextXAlignment = Enum.TextXAlignment.Left

	local ativo = false

	option.MouseButton1Click:Connect(function()

		ativo = not ativo

		if ativo then
			option.Text = "   "..v.."  ▣"
			selecionados[v] = true
		else
			option.Text = "   "..v.."  ☐"
			selecionados[v] = nil
		end
		
		-- Atualizar texto do botão
		local count = 0
		for _ in pairs(selecionados) do
			count += 1
		end

		if count == 0 then
			dropdownText.Text = "Select"
		else
			dropdownText.Text = count.." Selected"
		end

		print("Selecionados:")
		for k in pairs(selecionados) do
			print(k)
		end

	end)

end

