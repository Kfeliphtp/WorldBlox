local function criarBotao(nome)

	local btn = Instance.new("ImageButton")
	btn.Parent = BrainrotRaridadeBuy
	btn.Size = UDim2.new(1, -20, 0, 30)
	btn.BackgroundTransparency = 1
	btn.Image = "rbxassetid://108930673431145"

	local txt = Instance.new("TextLabel")
	txt.Parent = btn
	txt.Size = UDim2.new(1, -40, 1, 0) -- deixa espaço pro check
	txt.Position = UDim2.new(0, 10, 0, 0)
	txt.BackgroundTransparency = 1
	txt.Font = Enum.Font.FredokaOne
	txt.Text = nome
	txt.TextColor3 = Color3.fromRGB(255, 255, 255)
	txt.TextSize = 18
	txt.TextXAlignment = Enum.TextXAlignment.Left

	-- CHECKBOX (☐ / ▣)
	local check = Instance.new("TextLabel")
	check.Parent = btn
	check.Size = UDim2.new(0, 30, 1, 0)
	check.Position = UDim2.new(1, -35, 0, 0) -- fica na direita
	check.BackgroundTransparency = 1
	check.Font = Enum.Font.FredokaOne
	check.Text = "☐"
	check.TextColor3 = Color3.fromRGB(0, 115, 223)
	check.TextSize = 23
	check.TextXAlignment = Enum.TextXAlignment.Center

	-- clique
	btn.MouseButton1Click:Connect(function()

		autoBuy[nome] = not autoBuy[nome]

		if autoBuy[nome] then
			check.Text = "▣"
		else
			check.Text = "☐"
		end

	end)
end

