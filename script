local player = game.Players.LocalPlayer

local function distancia(obj)
	if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
		return 0
	end

	local root = player.Character.HumanoidRootPart

	if obj:IsA("BasePart") then
		return math.floor((root.Position - obj.Position).Magnitude)
	elseif obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
		return math.floor((root.Position - obj.HumanoidRootPart.Position).Magnitude)
	end

	return 0
end

